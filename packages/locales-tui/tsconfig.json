{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "rootDir": "src",
        "outDir": "dist",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"]
}
