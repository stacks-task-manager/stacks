{
    "name": "@stacks/server",
    "version": "1.0.117",
    "type": "commonjs",
    "license": "AGPL-3.0-only",
    "scripts": {
        "build": "tsc --project tsconfig.json && node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','ai','prompts'),d=p.join('dist','ai','prompts');if(fs.existsSync(s)){fs.mkdirSync(p.dirname(d),{recursive:true});fs.cpSync(s,d,{recursive:true});}\"",
        "build:translations": "cd ../translations && yarn install && yarn build",
        "bundle": "yarn build:translations && yarn pre-bundle && node -e \"require('./esbuild.config.js').buildSecure()\" && yarn post-bundle",
        "bundle-unsecure": "node esbuild.config.js",
        "pre-bundle": "node pre-build.js",
        "post-bundle": "node post-build.js",
        "setup": "yarn install",
        "dev": "tsx watch --include \"./src/**/*.ts\" --include \"../translations/src/**/*.ts\" --include \"../db/src/**/*.ts\" --include \"../types/src/**/*.ts\" --include \"../license/src/**/*.ts\" --tsconfig tsconfig.dev.json --inspect --env-file=.env src/index.ts",
        "test": "vitest run",
        "test:unit": "vitest run --config vitest.unit.config.js"
    },
    "dependencies": {
        "@ai-sdk/openai": "^3.0.50",
        "@hono/node-server": "^1.14.1",
        "@hono/node-ws": "^1.1.4",
        "@hono/zod-validator": "^0.4.3",
        "@stacks/translations": "workspace:*",
        "@types/lodash": "^4.17.24",
        "ai": "^6.0.206",
        "bcryptjs": "^3.0.2",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.2",
        "exceljs": "^4.4.0",
        "google-auth-library": "^10.2.1",
        "googleapis": "^154.1.0",
        "handlebars": "^4.7.8",
        "hono": "^4.12.23",
        "lodash": "^4.17.23",
        "mime-types": "^3.0.2",
        "multer": "^2.0.2",
        "pdf2pic": "^3.2.0",
        "pg": "^8.15.6",
        "playwright-core": "^1.58.0",
        "puppeteer-core": "^24.0.0",
        "sequelize": "^6.37.7",
        "sharp": "^0.34.3",
        "typescript": "^5.8.3",
        "uuid": "^9.0.1",
        "zod": "^3.25.32"
    },
    "devDependencies": {
        "@stacks/db": "workspace:*",
        "@stacks/license": "workspace:*",
        "@stacks/types": "workspace:*",
        "@types/bcrypt": "^5.0.2",
        "@types/mime-types": "^3.0.1",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.11.17",
        "@types/pg": "^8.11.14",
        "@types/sequelize": "^4.28.20",
        "@types/uuid": "^9.0.8",
        "esbuild": "^0.25.8",
        "sequelize-cli": "^6.6.3",
        "tsx": "^4.7.1",
        "vitest": "^1.6.1"
    }
}
