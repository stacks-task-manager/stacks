# =============================================================================
# @stacks/server — environment configuration
# =============================================================================
# Copy this file to packages/server/.env and edit values for your environment.
# Secrets MUST be regenerated for production — never ship the defaults below.
# =============================================================================

# `development` enables verbose errors and the proxy-to-app-dev-server path in
# api.ts. Use `production` for any non-local deployment.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# See packages/db/env.example for full descriptions of each variable.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stacks

# Set to `true` to log every Sequelize SQL statement. Very noisy — debug only.
DEBUG_DB=false

# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------
# Port the Hono server listens on. The web app dev server (port 3001) proxies
# API requests to this port, so changing it requires app config updates too.
APP_PORT=3000

# Comma-separated list of allowed CORS origins. Leave unset (or empty) for a
# permissive CORS policy during local development. ALWAYS set this in
# production to the actual domain(s) that should access the API.
# CORS_ORIGINS=https://your-domain.example,https://admin.your-domain.example

# When true, refuses to start if COOKIE_SECRET / JWT_SECRET look weak. Enable
# in production. Leave off in dev for convenience.
# REQUIRE_SECRETS=1

# -----------------------------------------------------------------------------
# Secrets — REGENERATE THESE FOR PRODUCTION
# -----------------------------------------------------------------------------
# Generate strong values with: `openssl rand -hex 32`
#
# COOKIE_SECRET signs the auth session cookie. Rotating it logs everyone out.
COOKIE_SECRET=s3cr3t

# JWT_SECRET signs JWT bearer tokens (HS256). Same rotation cost as above.
JWT_SECRET=your-very-secret-key

# -----------------------------------------------------------------------------
# Files
# -----------------------------------------------------------------------------
# When `true`, deleting an attachment also removes the underlying file from
# disk. When `false` (default), DB row is removed but the blob is retained —
# useful for soft-delete-style workflows.
DELETE_FILES=false

# -----------------------------------------------------------------------------
# AGPL §13 — source disclosure
# -----------------------------------------------------------------------------
# If you fork Stacks and host a modified version, point this at YOUR source
# repository. Surfaced via GET /api/info to satisfy the AGPL network-use
# clause. Defaults to the upstream repo if unset.
# STACKS_SOURCE_URL=https://github.com/your-org/your-fork

# Optional commit SHA returned by /api/info. Set in CI with the actual SHA.
# STACKS_COMMIT_SHA=

# -----------------------------------------------------------------------------
# AI chat assistant (optional)
# -----------------------------------------------------------------------------
# Point at any OpenAI-compatible chat-completion endpoint — e.g. LM Studio,
# llama.cpp's server, vLLM, OpenAI, Together, etc. The model just has to
# support the /v1/chat/completions shape.
# AI_OPENAI_BASE_URL=http://localhost:8080/v1

# API key for the AI provider. For local servers this is often a placeholder.
# AI_API_KEY=lmstudio

# Identifier the AI provider uses for the loaded model.
# AI_MODEL=your-loaded-model-id

# Show the chat bubble in the app UI. Off by default.
# AI_CHAT_ENABLED=true

# When the assistant replies with a URL, automatically redirect the user there.
# Convenience for navigation-style assistants — disable if you don't trust it.
# AI_CHAT_AUTO_REDIRECT=true
