{
    "name": "@stacks/app",
    "version": "1.0.67",
    "homepage": "./",
    "description": "The kanban task manager for everyone",
    "license": "AGPL-3.0-only",
    "sideEffects": true,
    "scripts": {
        "start": "webpack serve --config webpack.config.cjs --mode development",
        "build": "yarn pre-bundle && webpack --config webpack.config.cjs --mode production",
        "test": "jest --config jest.config.cjs",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "setup": "yarn install",
        "pre-bundle": "node pre-build.js",
        "analyze": "source-map-explorer 'build/static/js/*.js'",
        "sprites": "svg-sprite-generate -d ./svg -o ./src/app/icons/sprites.svg"
    },
    "installConfig": {
        "hoistingLimits": "workspaces"
    },
    "dependencies": {
        "@blueprintjs/core": "^6.1.0",
        "@blueprintjs/datetime": "^6.0.1",
        "@blueprintjs/icons": "^6.0.0",
        "@blueprintjs/select": "^6.0.1",
        "@floating-ui/dom": "^1.6.0",
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.20",
        "@fullcalendar/interaction": "^6.1.20",
        "@fullcalendar/react": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "@hello-pangea/dnd": "^18.0.0",
        "@minoru/react-dnd-treeview": "^3.5.3",
        "@stacks/translations": "workspace:*",
        "@tiptap/core": "^3.20.4",
        "@tiptap/extension-code-block-lowlight": "^3.20.4",
        "@tiptap/extension-color": "^3.20.4",
        "@tiptap/extension-document": "^3.20.4",
        "@tiptap/extension-emoji": "^3.20.4",
        "@tiptap/extension-font-family": "^3.20.4",
        "@tiptap/extension-heading": "^3.20.4",
        "@tiptap/extension-highlight": "^3.20.4",
        "@tiptap/extension-image": "^3.20.4",
        "@tiptap/extension-link": "^3.20.4",
        "@tiptap/extension-list": "^3.20.4",
        "@tiptap/extension-mention": "^3.20.4",
        "@tiptap/extension-subscript": "^3.20.4",
        "@tiptap/extension-superscript": "^3.20.4",
        "@tiptap/extension-table": "^3.20.4",
        "@tiptap/extension-text-align": "^3.20.4",
        "@tiptap/extension-text-style": "^3.20.4",
        "@tiptap/extension-typography": "^3.20.4",
        "@tiptap/extension-underline": "^3.20.4",
        "@tiptap/extension-youtube": "^3.20.4",
        "@tiptap/extensions": "^3.20.4",
        "@tiptap/pm": "^3.20.4",
        "@tiptap/react": "^3.20.4",
        "@tiptap/starter-kit": "^3.20.4",
        "@tiptap/suggestion": "^3.20.4",
        "axios": "^1.3.4",
        "classnames": "^2.5.1",
        "date-fns": "^4.1.0",
        "hash-wasm": "^4.12.0",
        "html-react-parser": "^5.1.18",
        "immer": "^10.0.3",
        "leaflet": "^1.8.0",
        "lodash": "^4.17.21",
        "lodash-es": "^4.17.21",
        "lowlight": "^3.1.0",
        "markdown-to-jsx": "^7.4.0",
        "mousetrap": "^1.6.5",
        "nanoid": "^4.0.1",
        "node-emoji": "^1.11.0",
        "normalize.css": "^8.0.1",
        "qs": "^6.14.0",
        "rc-gantt": "../../third-party/rc-gantt/rc-gantt-0.3.2.tgz",
        "react": "^18.3.1",
        "react-color": "^2.19.3",
        "react-colorful": "^5.6.1",
        "react-countup": "^6.4.2",
        "react-day-picker": "^8.10.1",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^18.3.1",
        "react-dropzone": "^14.3.8",
        "react-intersection-observer": "^9.13.1",
        "react-leaflet": "^4.2.1",
        "react-router-dom": "^6.28.0",
        "recharts": "^2.15.0",
        "sass": "^1.53.0",
        "scroll-into-view-if-needed": "^3.0.10",
        "sortablejs": "^1.15.2",
        "tinycolor2": "^1.4.2",
        "tippy.js": "^6.3.7",
        "tributejs": "^5.1.3",
        "unist-util-visit-parents": "^5.1.0",
        "use-sync-external-store": "^1.5.0"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
        "@stacks/types": "workspace:*",
        "@svgr/webpack": "^8.1.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^5.16.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^13.5.0",
        "@types/classnames": "^2.3.1",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.14.182",
        "@types/mousetrap": "^1.6.9",
        "@types/node": "^22.13.10",
        "@types/node-emoji": "^1.8.1",
        "@types/prismjs": "^1.16.2",
        "@types/react": "^18.3.12",
        "@types/react-color": "^3.0.6",
        "@types/react-dom": "^18.3.1",
        "@types/react-leaflet": "^2.8.2",
        "@types/recharts": "^1.8.23",
        "@types/resize-observer-browser": "^0.1.7",
        "@types/sortablejs": "^1.15.8",
        "@types/tinycolor2": "^1.4.3",
        "@types/webpack-env": "^1.18.8",
        "@typescript-eslint/eslint-plugin": "^5.30.7",
        "@typescript-eslint/parser": "^5.30.7",
        "autoprefixer": "^10.4.20",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.2.1",
        "babel-preset-react-app": "^10.0.1",
        "copy-webpack-plugin": "^12.0.2",
        "css-loader": "^6.11.0",
        "css-minimizer-webpack-plugin": "^7.0.0",
        "eslint": "^8.20.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-import-resolver-typescript": "^3.4.1",
        "eslint-plugin-import": "^2.26.0",
        "eslint-plugin-prettier": "^4.0.0",
        "eslint-plugin-react": "^7.28.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-unused-imports": "^3.2.0",
        "eslint-webpack-plugin": "^4.2.0",
        "file-loader": "^6.2.0",
        "fork-ts-checker-webpack-plugin": "^9.0.2",
        "html-webpack-plugin": "^5.6.3",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "mini-css-extract-plugin": "^2.9.2",
        "postcss": "^8.4.49",
        "postcss-loader": "^8.1.1",
        "react-refresh": "^0.14.2",
        "resolve-url-loader": "^5.0.0",
        "sass-loader": "^16.0.4",
        "source-map-explorer": "^2.5.2",
        "source-map-loader": "^5.0.0",
        "style-loader": "^3.3.4",
        "svg-sprite-generator": "^0.0.7",
        "terser-webpack-plugin": "^5.3.11",
        "typescript": "^5.5.0",
        "webpack": "^5.101.3",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.2"
    },
    "eslintConfig": {
        "plugins": [
            "import",
            "react-hooks",
            "unused-imports"
        ],
        "parser": "@typescript-eslint/parser",
        "extends": [
            "plugin:@typescript-eslint/recommended",
            "plugin:react/recommended",
            "plugin:react-hooks/recommended"
        ],
        "rules": {
            "unused-imports/no-unused-imports": "warn",
            "no-console": "warn",
            "react/prop-types": "off",
            "semi": "off",
            "prefer-promise-reject-errors": 0,
            "@typescript-eslint/explicit-function-return-type": "off",
            "@typescript-eslint/no-non-null-assertion": "off",
            "@typescript-eslint/interface-name-prefix": "off",
            "jsx-a11y/anchor-is-valid": "off",
            "@typescript-eslint/no-extra-semi": "off"
        },
        "settings": {
            "react": {
                "version": "detect"
            },
            "import/resolver": {
                "typescript": {
                    "alwaysTryTypes": true,
                    "project": "tsconfig.json"
                },
                "node": {
                    "paths": [
                        "src"
                    ]
                }
            }
        },
        "globals": {
            "tinymce": true
        },
        "overrides": [
            {
                "files": [
                    "**/*.spec.ts",
                    "**/*.spec.tsx",
                    "**/__tests__/**/*"
                ],
                "env": {
                    "jest": true
                },
                "rules": {
                    "@typescript-eslint/ban-ts-comment": "off",
                    "@typescript-eslint/no-empty-function": "off"
                }
            }
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
