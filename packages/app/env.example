# =============================================================================
# @stacks/app — environment configuration (web dev server)
# =============================================================================
# Copy this file to packages/app/.env when you need to override defaults.
# Webpack reads this at `yarn dev:app` time. None of these are baked into the
# production build — the production bundle reads its server URL relatively.
# =============================================================================

# Port the Webpack dev server listens on. Make sure the @stacks/server
# (port 3000 by default) proxies API requests here for `/app/*` and `/static/*`
# in development mode (see packages/server/src/api.ts).
PORT=3001

# Set to `none` to prevent webpack-dev-server from opening a browser tab.
# Leave unset to use the OS default.
# BROWSER=none

# Whether to emit source maps in the dev build. Off by default for faster builds;
# turn on if you need to debug bundled output in the browser devtools.
# GENERATE_SOURCEMAP=false
