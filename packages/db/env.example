# =============================================================================
# @stacks/db — environment configuration
# =============================================================================
# Copy this file to packages/db/.env and edit values for your environment.
# These variables are only needed when running DB tooling directly
# (e.g. `yarn workspace @stacks/db migrate`). The server reads its own .env.
# =============================================================================

# Hostname of the Postgres server. Use `localhost` for a local install, or the
# container name (e.g. `postgres`) when running inside docker-compose.
POSTGRES_HOST=localhost

# TCP port. Postgres' default is 5432.
POSTGRES_PORT=5432

# Database role used to connect. For local dev, the default `postgres`
# superuser is fine; production should use a least-privilege role.
POSTGRES_USER=postgres

# Password for POSTGRES_USER. DO NOT use `postgres` in production.
POSTGRES_PASSWORD=postgres

# Database name. The migration tooling creates this DB on `yarn db:create`.
POSTGRES_DB=stacks

# Optional: set to `true` to log every SQL statement Sequelize issues.
# Verbose — leave off unless you're debugging a query.
# DEBUG_DB=false
