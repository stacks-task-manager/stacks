{
  "entityName": "Document",
  "tableName": "documents",
  "attributes": {
    "id": {
      "type": "UUID",
      "defaultValue": "UUIDV4",
      "primaryKey": true
    },
    "tenant": {
      "type": "UUID",
      "allowNull": false
    },
    "createdBy": {
      "type": "UUID",
      "allowNull": false
    },
    "updatedBy": {
      "type": "UUID",
      "allowNull": false
    },
    "deletedBy": {
      "type": "UUID",
      "allowNull": true
    },
    "created": {
      "type": "DATE",
      "defaultValue": "NOW",
      "allowNull": false
    },
    "updated": {
      "type": "DATE",
      "defaultValue": "NOW",
      "allowNull": false
    },
    "deleted": {
      "type": "DATE",
      "allowNull": true
    },
    "title": {
      "type": "STRING",
      "allowNull": false
    },
    "parent": {
      "type": "UUID",
      "allowNull": true,
      "defaultValue": null
    },
    "type": {
      "type": {
        "type": "ENUM",
        "values": [
          "...Object.values(RECORDTYPE"
        ]
      },
      "allowNull": false
    },
    "tint": {
      "type": "STRING",
      "allowNull": true
    },
    "order": {
      "type": "INTEGER",
      "allowNull": true,
      "defaultValue": 0
    },
    "hidden": {
      "type": "BOOLEAN",
      "allowNull": true,
      "defaultValue": false
    }
  },
  "options": {}
}