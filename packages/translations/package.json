{
    "name": "@stacks/translations",
    "version": "0.1.0",
    "description": "Lightweight runtime i18n: setTranslations + translate with interpolation and plurals",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "src/index.ts",
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "prepare": "tsc",
        "dev": "tsc --watch --preserveWatchOutput",
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "i18n",
        "translation",
        "intl"
    ],
    "license": "AGPL-3.0-only",
    "devDependencies": {
        "@types/node": "^25.9.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
