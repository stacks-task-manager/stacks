# =============================================================================
# @stacks/email-service — environment configuration
# =============================================================================
# Copy this file to packages/email-service/.env and edit for your environment.
# The service reads outbound mail from the same Postgres database as the
# server, so the POSTGRES_* variables must match server/.env.
# =============================================================================

# -----------------------------------------------------------------------------
# SMTP transport
# -----------------------------------------------------------------------------
# For LOCAL DEVELOPMENT, use a mail-capture server (everything below works for
# both MailHog and Mailpit):
#   docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
# Then set SMTP_HOST=localhost, SMTP_PORT=1025, SMTP_SECURE=false, no auth.
# View captured mail at http://localhost:8025
SMTP_HOST=smtp.example.com

# Common values: 25 (unencrypted, server-to-server), 465 (implicit TLS),
# 587 (STARTTLS — the standard for client submission). MailHog/Mailpit use 1025.
SMTP_PORT=587

# `true` to use implicit TLS (port 465). `false` if you're on 587 with STARTTLS
# or on a local capture server (1025).
SMTP_SECURE=false

# SMTP auth username — typically your full email address for hosted providers.
# Leave blank for local capture servers that don't require auth.
SMTP_USER=your-smtp-user

# SMTP auth password or application-specific password. NEVER commit a real one.
SMTP_PASSWORD=your-smtp-password

# Display name shown in the "From" header of outbound messages.
SMTP_FROM_NAME=Your App Name

# Address shown in the "From" header. Must be allowed by your SMTP provider —
# many hosts only let you send from verified domains.
SMTP_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Queue polling
# -----------------------------------------------------------------------------
# How often (milliseconds) the service polls the `email_queue` table for new
# rows. 60000 = once a minute. Lower this for snappier dev iteration; do NOT
# drop below ~5000ms in production — DB load scales linearly.
EMAIL_PROCESS_INTERVAL=60000

# -----------------------------------------------------------------------------
# Link building
# -----------------------------------------------------------------------------
# Base URL embedded into outbound emails (verification links, reset-password
# links, etc.). Must match how users actually reach the app. For local dev,
# this is http://localhost:3000. In production, the public HTTPS URL.
PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (must match server/.env)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stacks
