!.yarn/releases/
!.yarn/releases/**
.yarn/cache/
packages/**/.yarn/
pw-videos/
html-report/
results/
playwright.json
playwright/.auth/user.json

# deps
node_modules/
packages/app/node_modules/

# env
.env
.env.production
!packages/app/.env


# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# misc
.DS_Store
packages/app/src/app/locale/translations-backup.zip
packages/types/dist/
packages/types/*.tgz
third-party/rc-gantt/node_modules
third-party/rc-gantt/src/.umi
.yarn/install-state.gz
packages/server/uploads/
packages/server/previews/
packages/server/license
packages/license.key
packages/server/license.key
packages/server/public.pem
/releases/
scripts/release-signing/*.json
stacks-teams.zip
