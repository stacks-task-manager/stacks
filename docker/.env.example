# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stacks

# Application Configuration
APP_PORT=3000
DEBUG_DB=false
COOKIE_SECRET=your-cookie-secret-here
JWT_SECRET=your-jwt-secret-here
DELETE_FILES=false # whether to delete files completly from disk when deleting files via the API

# HTTP API response cache (GET/HEAD). Must be exactly "true" to enable.
CACHE=false

# Email Service Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Your App Name
SMTP_FROM_EMAIL=noreply@example.com
EMAIL_PROCESS_INTERVAL=60000
PUBLIC_URL=http://localhost:3000 # used when generating links in emails

# AI assistant (OpenAI-compatible local server: LM Studio, llama.cpp, etc.)
# Leave unset or empty to hide chat UI and disable WS handler.
AI_CHAT_ENABLED=true # whether to enable the chat bubble in the app
AI_OPENAI_BASE_URL=http://127.0.0.1:1234/v1
AI_OPENAI_API_KEY=not-needed
AI_MODEL=your-loaded-model-id
AI_CHAT_AUTO_REDIRECT=true # whether to automatically redirect users via the chat to the URL mentioned in the response
